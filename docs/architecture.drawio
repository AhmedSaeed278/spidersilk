<mxfile host="app.diagrams.net" agent="spidersilk-bootstrap" version="24.7.0">
  <diagram id="spidersilk-arch" name="Spidersilk">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="user" value="User browser" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ingress" value="Ingress / LB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="240" y="85" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="svc" value="Service (ClusterIP :80)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="430" y="85" width="160" height="50" as="geometry" />
        </mxCell>

        <mxCell id="podGroup" value="Pod: spidersilk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="40" width="380" height="220" as="geometry" />
        </mxCell>
        <mxCell id="nginx" value="nginx&#10;(:8080)&#10;serves /static/*, proxies /" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#444;" vertex="1" parent="podGroup">
          <mxGeometry x="20" y="40" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="app" value="app: FastAPI&#10;(uvicorn :8000)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#444;" vertex="1" parent="podGroup">
          <mxGeometry x="200" y="40" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="vol" value="emptyDir /public&#10;(shared, not NFS)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666;" vertex="1" parent="podGroup">
          <mxGeometry x="100" y="140" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e_nginx_vol" style="endArrow=open;dashed=1;" edge="1" parent="podGroup" source="nginx" target="vol"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_app_vol"  style="endArrow=open;dashed=1;" edge="1" parent="podGroup" source="app"   target="vol"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_nginx_app" style="endArrow=block;" edge="1" parent="podGroup" source="nginx" target="app"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="s3" value="S3 bucket&#10;versioned, SSE-S3&#10;lifecycle → GLACIER @30d" style="shape=mxgraph.aws4.s3;html=1;labelPosition=right;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1120" y="120" width="78" height="78" as="geometry" />
        </mxCell>

        <mxCell id="cluster" value="K8s cluster (kops / AWS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="1160" height="280" as="geometry" />
        </mxCell>
        <mxCell id="cp" value="3x Control plane&#10;(t3.medium, HA across 3 AZs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#444;" vertex="1" parent="cluster">
          <mxGeometry x="40" y="50" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ng1" value="Node group: on-demand&#10;m5.large, 2–6&#10;label: lifecycle=on-demand" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#444;" vertex="1" parent="cluster">
          <mxGeometry x="320" y="50" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ng2" value="Node group: spot (mixed)&#10;m5/m5a/m5n/m4/m6i.large, 0–20&#10;taint: spot=true:NoSchedule" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#444;" vertex="1" parent="cluster">
          <mxGeometry x="640" y="50" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ca" value="Cluster Autoscaler&#10;(ASG auto-discovery,&#10;least-waste expander)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#444;" vertex="1" parent="cluster">
          <mxGeometry x="940" y="50" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="hpa" value="HPA: CPU 70% / Mem 80%, 2–10 replicas&#10;PDB: minAvailable=1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#444;" vertex="1" parent="cluster">
          <mxGeometry x="40" y="170" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="iam" value="IRSA: ServiceAccount → IAM role&#10;policy: s3:Put/Get/List on bucket only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#444;" vertex="1" parent="cluster">
          <mxGeometry x="580" y="170" width="560" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e_user_ing" style="endArrow=block;" edge="1" parent="1" source="user"    target="ingress"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ing_svc"  style="endArrow=block;" edge="1" parent="1" source="ingress" target="svc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_svc_pod"  style="endArrow=block;" edge="1" parent="1" source="svc"     target="podGroup"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_app_s3"   style="endArrow=block;dashed=0;" edge="1" parent="1" source="app" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ca_ng1"   style="endArrow=open;dashed=1;" edge="1" parent="1" source="ca" target="ng1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_ca_ng2"   style="endArrow=open;dashed=1;" edge="1" parent="1" source="ca" target="ng2"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
